<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>dOCEANi | Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F7F5F2;--bg2:#EEEBE6;--white:#FFFFFF;
  --ink:#1C1C1E;--ink2:#5A5A6A;--ink3:#9A9AAA;
  --accent:#2563EB;--accent2:#1D4ED8;
  --ease:cubic-bezier(0.22,1,0.36,1);
}
html{scroll-behavior:smooth}
body{font-family:'Be Vietnam Pro',sans-serif;background:var(--bg);color:var(--ink);cursor:none;overflow-x:hidden}

/* Cursor */
#cur{position:fixed;top:0;left:0;z-index:9999;pointer-events:none;width:12px;height:12px;background:var(--accent);border-radius:50%;transform:translate(-50%,-50%);transition:width .25s var(--ease),height .25s var(--ease),background .2s}
#cur-ring{position:fixed;top:0;left:0;z-index:9998;pointer-events:none;width:36px;height:36px;border:1.5px solid rgba(37,99,235,.4);border-radius:50%;transform:translate(-50%,-50%);transition:all .45s var(--ease)}
#cur.big{width:56px;height:56px;background:rgba(37,99,235,.12)}

/* Film grain */
body::after{content:'';position:fixed;inset:0;z-index:9997;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");
  background-size:180px;opacity:.5;animation:grain .4s steps(1) infinite}
@keyframes grain{0%,100%{background-position:0 0}12%{background-position:-4% -8%}25%{background-position:-14% 4%}37%{background-position:6% -22%}50%{background-position:-4% 22%}62%{background-position:-13% 8%}75%{background-position:13% 0%}87%{background-position:2% 13%}}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;z-index:500;padding:1.1rem 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(247,245,242,.9);backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,0,0,.06);transition:box-shadow .3s}
nav.scrolled{box-shadow:0 2px 24px rgba(0,0,0,.07)}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.55rem;letter-spacing:3px;color:var(--ink);text-decoration:none}
.logo-img{text-decoration:none;display:flex;align-items:center}
.logo-img img{height:36px;width:auto;display:block;filter:brightness(0)}
.nav-links{display:flex;gap:1.8rem;list-style:none}
.nav-links a{text-decoration:none;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink2);position:relative;padding-bottom:3px;transition:color .2s}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1.5px;background:var(--accent);transition:width .3s var(--ease)}
.nav-links a:hover{color:var(--ink)}
.nav-links a:hover::after{width:100%}

/* Hero */
#hero{min-height:100vh;display:flex;align-items:center;padding:8rem 5% 5rem;position:relative;overflow:hidden;background:var(--bg)}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;width:100%;max-width:1200px}
.hero-eyebrow{font-size:.75rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--accent);margin-bottom:1.5rem;display:flex;align-items:center;gap:.8rem;opacity:0;transform:translateY(18px);animation:fadeUp .8s var(--ease) .3s forwards}
.hero-eyebrow::before{content:'';width:28px;height:2px;background:var(--accent);flex-shrink:0}
h1.hero-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(5rem,11vw,9.5rem);line-height:.88;letter-spacing:3px;color:var(--ink);margin-bottom:1.8rem}
h1.hero-name .line{display:block;overflow:hidden}
h1.hero-name .line span{display:block;transform:translateY(105%);animation:slideUp .9s var(--ease) forwards}
h1.hero-name .line:nth-child(1) span{animation-delay:.5s}
.hero-bio{font-size:1rem;font-weight:300;color:var(--ink2);line-height:1.85;max-width:480px;margin-bottom:2.5rem;opacity:0;transform:translateY(18px);animation:fadeUp .8s var(--ease) 1s forwards}
.hero-bio strong{font-weight:600;color:var(--ink)}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;transform:translateY(18px);animation:fadeUp .8s var(--ease) 1.2s forwards}
.btn-p{display:inline-flex;align-items:center;gap:.6rem;background:var(--accent);color:#fff;text-decoration:none;font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.85rem 1.8rem;border-radius:3px;transition:background .2s,transform .25s var(--ease),box-shadow .25s}
.btn-p:hover{background:var(--accent2);transform:translateY(-3px);box-shadow:0 10px 28px rgba(37,99,235,.3)}
.btn-s{display:inline-flex;align-items:center;gap:.6rem;background:transparent;color:var(--ink);text-decoration:none;font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.85rem 1.8rem;border-radius:3px;border:1.5px solid rgba(0,0,0,.15);transition:border-color .2s,transform .25s var(--ease)}
.btn-s:hover{border-color:var(--ink);transform:translateY(-3px)}
.hero-right{opacity:0;transform:translateY(30px);animation:fadeUp .9s var(--ease) .8s forwards}
.showreel-wrap{position:relative;border-radius:6px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.18);aspect-ratio:16/9;background:#000}
.showreel-wrap iframe{width:100%;height:100%;border:0;display:block}
.showreel-label{position:absolute;bottom:12px;left:12px;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);color:#fff;font-size:.65rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.3rem .7rem;border-radius:2px}
.hero-stats{display:flex;gap:2.5rem;margin-top:2.5rem;opacity:0;animation:fadeUp .8s var(--ease) 1.5s forwards}
.stat-n{font-family:'Bebas Neue',sans-serif;font-size:2.6rem;line-height:1;letter-spacing:1px;color:var(--ink)}
.stat-n span{color:var(--accent)}
.stat-l{font-size:.65rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--ink3);margin-top:.2rem}

/* Section commons */
section{padding:6rem 5%}
.s-label{font-size:.72rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:.8rem;display:flex;align-items:center;gap:.7rem}
.s-label::before{content:'';width:22px;height:2px;background:var(--accent);flex-shrink:0}
.s-label::after{content:'';width:22px;height:2px;background:var(--accent);flex-shrink:0}
.s-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.4rem,5vw,3.8rem);letter-spacing:1px;line-height:1;color:var(--ink);margin-bottom:1rem}
.s-sub{font-size:.95rem;font-weight:300;color:var(--ink2);line-height:1.75;max-width:540px}
.reveal{opacity:0;transform:translateY(36px);transition:opacity .8s var(--ease),transform .8s var(--ease)}
.reveal.in{opacity:1;transform:none}

/* Personal Projects */
#personal{background:var(--bg2)}
.proj-list{display:flex;flex-direction:column;gap:5rem;margin-top:3rem}
.proj-item{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center}
.proj-item:nth-child(even) .proj-video{order:2}
.proj-item:nth-child(even) .proj-info{order:1}
.proj-video-wrap{position:relative;border-radius:5px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.14);aspect-ratio:16/9;background:#111}
.proj-video-wrap iframe{width:100%;height:100%;border:0;display:block}
.proj-tag{display:inline-block;font-size:.65rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);border:1.5px solid var(--accent);padding:.2rem .7rem;border-radius:2px;margin-bottom:.8rem}
.proj-title{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:1px;color:var(--ink);margin-bottom:1rem;line-height:1.05}
.proj-desc{font-size:.9rem;font-weight:300;color:var(--ink2);line-height:1.8}
.proj-desc-vi{margin-bottom:.8rem}
.proj-desc-en{font-style:italic;font-size:.85rem;color:var(--ink3);border-left:2px solid var(--accent);padding-left:.8rem;line-height:1.7}

/* Client Work */
#clients{background:var(--bg)}
.client-groups{display:flex;flex-direction:column;gap:4rem;margin-top:3rem}
.client-group-header{display:flex;align-items:center;gap:1.2rem;margin-bottom:1.5rem}
.client-logo-badge{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;background:var(--ink);color:#fff;padding:.4rem 1rem;border-radius:3px;white-space:nowrap}
.client-line{flex:1;height:1px;background:rgba(0,0,0,.1)}

/* 16:9 grid (Hanakoishi, Habitrade, More) */
.client-videos{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;align-items:start}
.client-vid-wrap{position:relative;border-radius:4px;overflow:hidden;box-shadow:0 8px 28px rgba(0,0,0,.1);aspect-ratio:16/9;background:#111;transition:transform .35s var(--ease),box-shadow .35s}
.client-vid-wrap:hover{transform:translateY(-4px);box-shadow:0 16px 44px rgba(0,0,0,.18)}
.client-vid-wrap iframe{width:100%;height:100%;border:0;display:block}

/* 9:16 Shorts grid */
.client-videos.shorts{grid-template-columns:repeat(6,1fr);gap:1rem}
.client-vid-wrap.short{aspect-ratio:9/16}
@media(max-width:1100px){.client-videos.shorts{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.client-videos.shorts{grid-template-columns:repeat(2,1fr)}}

/* Visual Design */
#visual{background:var(--bg2)}
.design-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-top:2.5rem}
.design-card{border-radius:5px;overflow:hidden;position:relative;box-shadow:0 8px 28px rgba(0,0,0,.1);aspect-ratio:4/3;background:var(--ink);transition:transform .35s var(--ease),box-shadow .35s}
.design-card:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,.18)}
.design-card img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s var(--ease)}
.design-card:hover img{transform:scale(1.04)}
.design-card-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,28,30,.85) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:1.2rem}
.design-card:hover .design-card-overlay{opacity:1}
.design-card-label{font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#fff}
.design-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--ink) 0%,var(--ink2) 100%)}
.design-placeholder span{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:3px;color:rgba(255,255,255,.15)}

/* About */
#about{background:var(--bg)}
.about-wrap{display:grid;grid-template-columns:1fr 1.3fr;gap:5rem;align-items:start}
.about-photo-col{position:relative}
.about-img-frame{position:relative;border-radius:5px;overflow:hidden;aspect-ratio:4/5;background:linear-gradient(160deg,#1c1c1e 0%,#3a3a5c 100%);box-shadow:0 30px 80px rgba(0,0,0,.2)}
.about-img-frame img{width:100%;height:100%;object-fit:cover;display:block}
.about-corner{position:absolute;bottom:-14px;right:-14px;width:70px;height:70px;background:var(--accent);border-radius:3px;z-index:-1}
.exp-badge{position:absolute;top:1.5rem;right:-1.8rem;background:var(--white);border-radius:4px;box-shadow:0 10px 36px rgba(0,0,0,.14);padding:1rem 1.2rem;text-align:center;min-width:100px}
.exp-n{font-family:'Bebas Neue',sans-serif;font-size:2.6rem;line-height:1;color:var(--accent)}
.exp-l{font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink3);margin-top:.2rem}
.about-text-col p{font-size:.92rem;font-weight:300;color:var(--ink2);line-height:1.85;margin-bottom:1rem}
.about-text-col p strong{font-weight:600;color:var(--ink)}
.about-bilingual{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1rem}
.lang-block{border-left:2px solid var(--accent);padding-left:1rem}
.lang-tag{font-size:.62rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.4rem}
.lang-text{font-size:.88rem;font-weight:300;color:var(--ink2);line-height:1.7}
.toolkit{margin-top:2rem}
.toolkit-title{font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--ink);margin-bottom:1rem}
.toolkit-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
.tool-item{display:flex;align-items:center;gap:.6rem;font-size:.82rem;font-weight:500;color:var(--ink)}
.tool-dot{width:5px;height:5px;background:var(--accent);border-radius:50%;flex-shrink:0}

/* Contact */
#contact{background:var(--ink);color:#fff;text-align:center;position:relative;overflow:hidden}
#contact::before{content:'dOCEANi';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Bebas Neue',sans-serif;font-size:clamp(5rem,18vw,13rem);letter-spacing:6px;color:rgba(255,255,255,.03);white-space:nowrap;pointer-events:none}
#contact .s-label{justify-content:center}
#contact .s-label::before,#contact .s-label::after{background:rgba(255,255,255,.3)}
#contact .s-title{color:#fff;margin-bottom:.8rem}
#contact .s-sub{color:rgba(255,255,255,.45);margin:0 auto 2.5rem;text-align:center}
.contact-email{display:block;font-family:'Bebas Neue',sans-serif;font-size:clamp(1.8rem,4vw,3.2rem);letter-spacing:2px;color:#fff;text-decoration:none;margin:1.5rem auto 2.5rem;position:relative;z-index:1;transition:color .2s}
.contact-email:hover{color:var(--accent)}
.contact-row{display:flex;justify-content:center;gap:.8rem;flex-wrap:wrap;position:relative;z-index:1}
.c-link{display:inline-flex;align-items:center;gap:.6rem;text-decoration:none;font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.12);padding:.75rem 1.5rem;border-radius:3px;transition:all .2s}
.c-link:hover{background:var(--accent);border-color:var(--accent);color:#fff;transform:translateY(-2px)}
.contact-phone{font-size:.85rem;color:rgba(255,255,255,.35);margin-top:2rem;letter-spacing:.08em;position:relative;z-index:1}

/* Footer */
footer{background:#111;padding:1.4rem 5%;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.8rem}
footer p{font-size:.72rem;color:rgba(255,255,255,.25);letter-spacing:.06em}
footer .logo{color:rgba(255,255,255,.6);font-size:1.2rem;letter-spacing:3px}
footer .logo-img img{height:28px;filter:brightness(0) invert(1);opacity:.6}

/* Animations */
@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}
@keyframes slideUp{to{transform:translateY(0)}}

/* Responsive */
@media(max-width:900px){
  .hero-grid,.about-wrap{grid-template-columns:1fr;gap:3rem}
  .hero-right{order:-1}
  .exp-badge{right:1rem}
  .proj-item{grid-template-columns:1fr}
  .proj-item:nth-child(even) .proj-video,.proj-item:nth-child(even) .proj-info{order:unset}
  .client-videos{grid-template-columns:1fr 1fr}
  .about-bilingual{grid-template-columns:1fr}
  .design-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:600px){
  .client-videos{grid-template-columns:1fr}
  .design-grid{grid-template-columns:1fr}
  .hero-stats{gap:1.5rem}
}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<div id="cur"></div>
<div id="cur-ring"></div>

<!-- NAV -->
<nav id="nav">
  <a href="#hero" class="logo-img"><img src="data:image/png;base64," alt="dOCEANi" /></a>
  <ul class="nav-links">
    <li><a href="#personal">Personal</a></li>
    <li><a href="#clients">Client Work</a></li>
    <li><a href="#visual">Visual Design</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-grid">
    <div class="hero-left">
      <p class="hero-eyebrow">Video Editor &amp; Visual Designer</p>
      <h1 class="hero-name">
        <span class="line"><span>DOCEANI</span></span>
      </h1>
      <p class="hero-bio">
        Hiện tại đang sống và làm việc tại <strong>Thành phố Cần Thơ</strong>,
        với hơn <strong>3 năm kinh nghiệm</strong> chỉnh sửa video —
        gửi gắm vào mỗi sản phẩm không chỉ là một file video hoàn thiện,
        mà là <strong>một câu chuyện có hồn được kể bằng ngôn ngữ hình ảnh</strong>.
      </p>
      <div class="hero-cta">
        <a href="#personal" class="btn-p">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><polygon points="2,1 11,6.5 2,12" fill="white"/></svg>
          Xem Projects
        </a>
        <a href="#contact" class="btn-s">Liên hệ hợp tác</a>
      </div>
      <div class="hero-stats">
        <div><div class="stat-n">3<span>+</span></div><div class="stat-l">Năm kinh nghiệm</div></div>
        <div><div class="stat-n">5<span>+</span></div><div class="stat-l">Clients lớn</div></div>
        <div><div class="stat-n">∞</div><div class="stat-l">Stories told</div></div>
      </div>
    </div>
    <div class="hero-right">
      <div class="showreel-wrap">
        <iframe src="https://www.youtube.com/embed/TXeAlggmTKo?rel=0&modestbranding=1" title="SHOWREEL 2025 — dOCEANi" allowfullscreen loading="lazy"></iframe>
        <span class="showreel-label">▶ SHOWREEL 2025</span>
      </div>
    </div>
  </div>
</section>

<!-- PERSONAL PROJECTS -->
<section id="personal">
  <div class="reveal">
    <p class="s-label">Dự án cá nhân</p>
    <h2 class="s-title">Personal Projects</h2>
    <p class="s-sub">Những dự án thể hiện phong cách kể chuyện và tư duy dựng phim của tôi.</p>
  </div>
  <div class="proj-list">

    <div class="proj-item reveal">
      <div class="proj-video">
        <div class="proj-video-wrap">
          <iframe src="https://www.youtube.com/embed/52SjJ_rWVvI?rel=0&modestbranding=1" title="RECAP 2025" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
      <div class="proj-info">
        <span class="proj-tag">Personal · 2025</span>
        <h3 class="proj-title">RECAP 2025<br>A Year of Memories</h3>
        <p class="proj-desc proj-desc-vi">Một năm 2025 nhiều kỷ niệm được gói gọn trong dự án cá nhân này. Việc sử dụng tỷ lệ khung hình 1:1 kết hợp cùng tông màu hoài niệm đã giúp tạo ra chiều sâu cảm xúc. Đây cũng là cách rèn luyện tư duy kể chuyện: dùng màu sắc, âm thanh và nhịp cắt dựng để biến những kỷ niệm đời thường thành một sản phẩm hấp dẫn.</p>
        <p class="proj-desc proj-desc-en">Using a 1:1 aspect ratio combined with nostalgic color tones to create emotional depth — turning everyday memories into an engaging product through colors, sound, and editing pace.</p>
      </div>
    </div>

    <div class="proj-item reveal">
      <div class="proj-info">
        <span class="proj-tag">Personal · 2026</span>
        <h3 class="proj-title">AN GIANG RECAP 2026<br>Youth Journey</h3>
        <p class="proj-desc proj-desc-vi">Lấy cảm hứng từ chuyến đi phượt cùng nhóm bạn đến tỉnh An Giang vào đầu năm 2026, dự án này lưu giữ lại vibe năng động của chuyến đi. Kết hợp các kỹ thuật Edit Trending cùng giai điệu nhạc nền bắt tai.</p>
        <p class="proj-desc proj-desc-en">Inspired by a road trip to An Giang province. A creative playground to showcase rhythm and visual pacing through trending editing techniques and a catchy soundtrack.</p>
      </div>
      <div class="proj-video">
        <div class="proj-video-wrap">
          <iframe src="https://www.youtube.com/embed/_WV9W7KxVKU?rel=0&modestbranding=1" title="An Giang Recap 2026" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
    </div>

    <div class="proj-item reveal">
      <div class="proj-video">
        <div class="proj-video-wrap">
          <iframe src="https://www.youtube.com/embed/zIIdWZx_quM?rel=0&modestbranding=1" title="Tần Số Short Film" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
      <div class="proj-info">
